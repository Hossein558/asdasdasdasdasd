<atlassian-plugin key="ir.atlassian.jira.plugins.persian-calendar-plugin" name="Persian Calendar Plugin" plugins-version="2">
    <plugin-info>
        <description>Persian/Shamsi calendar for Jira - Provided by DesktopCenter.ir</description>
        <version>${project.version}</version>
        <vendor name="DesktopCenter" url="https://desktopcenter.ir/" />
        <param name="plugin-icon">images/pluginIcon.png</param>
        <param name="plugin-logo">images/pluginLogo.png</param>
        <param name="atlassian-data-center-status">compatible</param>
        <param name="atlassian-data-center-compatible">true</param>
    </plugin-info>

    <!-- Web Resources for Persian Calendar -->
    <!-- LicenseCondition gates this entire bundle: when license is invalid,
         Jira's web-resource manager will not emit the <script>/<link> tags
         for this bundle. The browser never downloads the JS or CSS. -->
    <web-resource key="persian-calendar-resources" name="Persian Calendar Resources">
        <condition class="ir.atlassian.jira.plugins.license.LicenseCondition"/>
        <description>JavaScript and CSS for Persian Calendar</description>
        <dependency>com.atlassian.auiplugin:ajs</dependency>

        <resource type="download" name="persian-calendar.js" location="/js/persian-calendar.js"/>
        <resource type="download" name="persian-calendar.css" location="/css/persian-calendar.css"/>
        <resource type="download" name="jalaali.js" location="/js/jalaali.js"/>

        <context>atl.general</context>
        <context>jira.general</context>
        <context>jira.view.issue</context>
        <context>jira.create.issue</context>
        <context>jira.edit.issue</context>
        <context>jira.navigator.advanced</context>
        <context>jira.navigator.simple</context>
        <context>jira.search</context>
        <context>atl.admin</context>
        <!-- JSM Customer Portal contexts -->
        <context>customerportal</context>
        <context>sd.general</context>
        <context>sd.request.create</context>
        <context>sd.request.view</context>
    </web-resource>

    <!-- Web Panel to inject additional markup if needed -->
    <!-- Same LicenseCondition: don't inject the init markup when unlicensed -->
    <web-panel key="persian-calendar-panel" location="atl.header.after.scripts" weight="1000">
        <condition class="ir.atlassian.jira.plugins.license.LicenseCondition"/>
        <description>Initializes Persian Calendar</description>
        <resource name="view" type="velocity" location="/templates/persian-calendar-init.vm"/>
    </web-panel>

    <!-- License Admin Servlet -->
    <servlet key="license-servlet" name="Persian Calendar License Admin" class="ir.atlassian.jira.plugins.servlet.LicenseServlet">
        <description>License management page for Persian Calendar</description>
        <url-pattern>/persian-calendar/license</url-pattern>
    </servlet>

    <!-- Admin Menu Link -->
    <web-item key="persian-calendar-license-link" name="Persian Calendar License" section="system.admin/system" weight="100">
        <description>Link to Persian Calendar license management</description>
        <label>لایسنس تقویم فارسی</label>
        <link>/plugins/servlet/persian-calendar/license</link>
    </web-item>

    <!-- REST API for Date Format Settings -->
    <rest key="persian-calendar-rest" path="/persian-calendar" version="1.0">
        <description>REST API for Persian Calendar Plugin - provides date format settings</description>
        <package>ir.atlassian.jira.plugins.rest</package>
    </rest>

</atlassian-plugin>
